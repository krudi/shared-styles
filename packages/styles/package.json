{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "@krudi/styles",
    "version": "0.1.10",
    "private": false,
    "description": "Reusable CSS foundations, components, and utilities extracted from krudi-io for sharing across projects.",
    "keywords": [
        "css",
        "styles",
        "utilities",
        "components",
        "theme",
        "variables"
    ],
    "homepage": "https://github.com/krudi/shared-styles#readme",
    "bugs": {
        "url": "https://github.com/krudi/shared-styles/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/krudi/shared-styles.git"
    },
    "license": "MIT",
    "author": {
        "name": "krudi",
        "email": "patryk.kudlik@gmail.com",
        "url": "https://krudi.io"
    },
    "type": "module",
    "exports": {
        "./css": "./dist/styles/index.css",
        "./css/palette": "./dist/styles/palette.css",
        "./css/variables": "./dist/styles/variables.css",
        "./css/theme": "./dist/styles/theme.css",
        "./css/base": "./dist/styles/base/index.css",
        "./css/layout": "./dist/styles/layout/index.css",
        "./css/components": "./dist/styles/components/index.css",
        "./css/forms": "./dist/styles/forms/index.css",
        "./css/utilities": "./dist/styles/utilities/index.css",
        "./css/html": "./dist/styles/html/index.css",
        "./js": {
            "types": "./dist/scripts/index.d.ts",
            "import": "./dist/scripts/index.js"
        },
        "./js/modal": {
            "types": "./dist/scripts/modal.d.ts",
            "import": "./dist/scripts/modal.js"
        },
        "./js/theme-switch": {
            "types": "./dist/scripts/theme-switch.d.ts",
            "import": "./dist/scripts/theme-switch.js"
        },
        "./forms": "./dist/styles/forms/index.css",
        "./utilities": "./dist/styles/utilities/index.css",
        "./html": "./dist/styles/html/index.css"
    },
    "main": "./dist/styles/index.css",
    "style": "./dist/styles/index.css",
    "files": [
        "assets",
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc -b tsconfig.build.json && postcss \"src/styles/**/*.css\" --base src/styles --dir dist/styles --map",
        "clean": "rm -rf .turbo .cache node_modules",
        "dev": "tsc -p tsconfig.json --watch & postcss \"src/styles/**/*.css\" --base src/styles --dir dist/styles --map --watch",
        "lint:eslint": "eslint --flag unstable_native_nodejs_ts_config . --cache --cache-location .cache/.eslintcache",
        "lint:eslint:fix": "eslint --flag unstable_native_nodejs_ts_config . --fix --cache --cache-location .cache/.eslintcache",
        "lint:prettier": "prettier --check . --cache --cache-strategy metadata --cache-location .cache/.prettiercache",
        "lint:prettier:fix": "prettier --write . --cache --cache-strategy metadata --cache-location .cache/.prettiercache",
        "lint:stylelint": "stylelint --cache --cache-location .cache/.stylelintcache -c ./stylelint.config.ts \"**/*.css\"",
        "lint:stylelint:fix": "stylelint --cache --cache-location .cache/.stylelintcache -c ./stylelint.config.ts --fix \"**/*.css\"",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "dependencies": {
        "@krudi/icons": "*"
    },
    "devDependencies": {
        "@krudi/eslint-config": "^0.1.8",
        "@krudi/prettier-config": "^0.1.8",
        "@krudi/stylelint-config": "^0.1.1",
        "@types/node": "^25.5.2",
        "autoprefixer": "^10.4.27",
        "cssnano": "^7.1.4",
        "postcss": "^8.5.8",
        "postcss-cli": "^11.0.1",
        "postcss-import": "^16.1.1",
        "postcss-load-config": "^6.0.1",
        "postcss-nesting": "^14.0.0",
        "typescript": "^6.0.2"
    },
    "engines": {
        "node": ">= 24.14.0"
    }
}
