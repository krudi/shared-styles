* text=auto eol=lf

# TypeScript
*.ts                text eol=lf
*.js                text eol=lf
*.d.ts              text eol=lf

# Configuration & metadata
*.json              text eol=lf diff=json
*.tsbuildinfo       text eol=lf
tsconfig*.json      text eol=lf diff=json

# Documentation
*.md                text eol=lf diff=markdown

# Styles & markup
*.css               text eol=lf diff=css
*.svg               text eol=lf

# Binary assets
*.png               binary
*.jpg               binary
*.jpeg              binary
*.gif               binary
*.webp              binary
*.ico               binary
*.ttf               binary
*.otf               binary
*.woff              binary
*.woff2             binary

# Export rules
assets/             -export-ignore
assets/**           -export-ignore
dist/               -export-ignore
dist/**             -export-ignore
LICENSE             -export-ignore
README.md           -export-ignore
package.json        -export-ignore
.cache/             export-ignore
.cache/**           export-ignore
.turbo/             export-ignore
.turbo/**           export-ignore
node_modules/       export-ignore
node_modules/**     export-ignore
src/                export-ignore
src/**              export-ignore
.gitignore          export-ignore
.gitattributes      export-ignore
.prettierignore     export-ignore
eslint.config.ts    export-ignore
postcss.config.json export-ignore
prettier.config.ts  export-ignore
stylelint.config.ts export-ignore
tsconfig*.json      export-ignore
